{
  "version": 8,
  "name": "Australia Is Beautiful",
  "glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
  "sources": {
    "aib": {
      "type": "vector",
      "url": "pmtiles:///map/australia.pmtiles",
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f4f2ea" }
    },

    {
      "id": "landcover-farmland",
      "type": "fill",
      "source": "aib",
      "source-layer": "landcover",
      "filter": ["in", "class", "farmland", "grass"],
      "paint": { "fill-color": "#eeeee2" }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "aib",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#dde6d2",
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          0.4,
          9,
          0.7
        ]
      }
    },

    {
      "id": "park",
      "type": "fill",
      "source": "aib",
      "source-layer": "park",
      "minzoom": 9,
      "paint": {
        "fill-color": "#d3e3c2",
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          9,
          0,
          11,
          0.85
        ]
      }
    },

    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "aib",
      "source-layer": "landuse",
      "filter": ["in", "class", "residential", "suburb", "neighbourhood"],
      "paint": { "fill-color": "#f1efe6" }
    },

    {
      "id": "water",
      "type": "fill",
      "source": "aib",
      "source-layer": "water",
      "filter": ["!=", "brunnel", "tunnel"],
      "paint": {
        "fill-color": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          "#a8c8cc",
          10,
          "#c2d8da"
        ]
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "aib",
      "source-layer": "waterway",
      "minzoom": 8,
      "paint": {
        "line-color": "#c2d8da",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.8, 14, 3]
      }
    },

    {
      "id": "building",
      "type": "fill",
      "source": "aib",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#e9e5d9",
        "fill-opacity": 0.7
      }
    },

    {
      "id": "roads-minor",
      "type": "line",
      "source": "aib",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "track"],
      "minzoom": 13,
      "paint": {
        "line-color": "#fbfaf5",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 1.2, 16, 5, 19, 15]
      }
    },

    {
      "id": "roads-secondary",
      "type": "line",
      "source": "aib",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "minzoom": 10,
      "paint": {
        "line-color": "#fbfaf5",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1.6, 14, 5.5, 18, 16]
      }
    },

    {
      "id": "roads-primary",
      "type": "line",
      "source": "aib",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk", "primary"],
      "paint": {
        "line-color": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          "#dcc9a4",
          10,
          "#f6f0e2"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 1.2, 10, 3.5, 14, 8, 18, 21]
      }
    },

    {
      "id": "boundary-state",
      "type": "line",
      "source": "aib",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "paint": {
        "line-color": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          "#b5ab96",
          9,
          "#d5cfc0"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 1.2, 9, 1],
        "line-dasharray": [4, 3]
      }
    },

    {
      "id": "place-suburb",
      "type": "symbol",
      "source": "aib",
      "source-layer": "place",
      "filter": ["in", "class", "suburb", "neighbourhood", "village", "hamlet"],
      "minzoom": 11,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11.5,
        "text-letter-spacing": 0.06,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#95998c",
        "text-halo-color": "#f7f5ee",
        "text-halo-width": 1.4
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "aib",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Medium"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 12, 10, 15],
        "text-max-width": 8
      },
      "paint": {
        "text-color": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          "#4f574a",
          10,
          "#6d7566"
        ],
        "text-halo-color": "#f7f5ee",
        "text-halo-width": 1.6
      }
    },
    {
      "id": "place-state",
      "type": "symbol",
      "source": "aib",
      "source-layer": "place",
      "filter": ["==", "class", "state"],
      "maxzoom": 7,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Medium"],
        "text-size": 12,
        "text-letter-spacing": 0.24,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#8f8878",
        "text-halo-color": "#f4f2ea",
        "text-halo-width": 1.6
      }
    }
  ]
}
